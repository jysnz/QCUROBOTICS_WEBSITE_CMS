#DATABASE CONTEXT

#Tables
create table public."Achievements" (
  achievement_id bigint generated by default as identity not null,
  achievement_name text not null,
  team_id bigint null,
  competition_id bigint null,
  national_award boolean null,
  international_award boolean null,
  constraint Achievements_pkey primary key (achievement_id),
  constraint Achievements_competition_id_fkey foreign KEY (competition_id) references competitions (id) on update CASCADE on delete CASCADE,
  constraint Achievements_team_id_fkey foreign KEY (team_id) references teams (id) on update CASCADE on delete CASCADE
) TABLESPACE pg_default;

create table public."Coaches" (
  id bigint generated by default as identity not null,
  name text not null,
  image_url text null,
  is_active boolean null,
  constraint Coaches_pkey primary key (id)
) TABLESPACE pg_default;

create table public.competitions (
  id bigint generated always as identity not null,
  title text not null,
  status text null,
  date text null,
  location text null,
  created_at timestamp with time zone null default now(),
  image_url text null,
  season_id bigint null,
  constraint competitions_pkey primary key (id),
  constraint competitions_season_id_fkey foreign KEY (season_id) references seasons (id) on update CASCADE on delete CASCADE
) TABLESPACE pg_default;

create table public.email_signups (
  id bigint generated always as identity not null,
  email text not null,
  created_at timestamp with time zone null default now(),
  constraint email_signups_pkey primary key (id),
  constraint email_signups_email_key unique (email)
) TABLESPACE pg_default;

create table public.matches (
  id bigint generated always as identity not null,
  competition_id bigint null,
  name text not null,
  our_score integer null default 0,
  opponent_score integer null default 0,
  opponent_name text null,
  result text GENERATED ALWAYS as (
    case
      when (our_score > opponent_score) then 'Win'::text
      when (our_score < opponent_score) then 'Loss'::text
      else 'Draw'::text
    end
  ) STORED null,
  video_url text null,
  created_at timestamp with time zone null default now(),
  team_id bigint null,
  sequence bigint null,
  thumbnail text null,
  is_processing boolean null default false,
  constraint matches_pkey primary key (id),
  constraint matches_competition_id_fkey foreign KEY (competition_id) references competitions (id) on delete CASCADE,
  constraint matches_team_id_fkey foreign KEY (team_id) references teams (id) on update CASCADE on delete CASCADE
) TABLESPACE pg_default;

create table public.media_team (
  id bigint generated by default as identity not null,
  name text not null,
  position text null,
  image_url text null,
  is_active boolean null,
  constraint media_team_pkey primary key (id)
) TABLESPACE pg_default;

create table public.member_roles (
  id bigint generated always as identity not null,
  member_id bigint not null,
  role_id bigint not null,
  season_id bigint not null,
  constraint member_roles_pkey primary key (id),
  constraint member_roles_member_fkey foreign KEY (member_id) references team_members (id) on delete CASCADE,
  constraint member_roles_role_fkey foreign KEY (role_id) references roles (id) on delete CASCADE,
  constraint member_roles_season_id_fkey foreign KEY (season_id) references seasons (id) on update CASCADE on delete CASCADE
) TABLESPACE pg_default;

create table public.member_team_seasons (
  id bigint generated always as identity not null,
  member_id bigint not null,
  team_id bigint not null,
  season_id bigint not null,
  constraint member_team_seasons_pkey primary key (id),
  constraint member_team_season_unique unique (member_id, team_id, season_id),
  constraint mts_member_fkey foreign KEY (member_id) references team_members (id) on delete CASCADE,
  constraint mts_season_fkey foreign KEY (season_id) references seasons (id) on delete CASCADE,
  constraint mts_team_fkey foreign KEY (team_id) references teams (id) on delete CASCADE
) TABLESPACE pg_default;

create table public.members (
  id bigint generated by default as identity not null,
  name text not null,
  image_url text null,
  is_active boolean null,
  constraint members_pkey primary key (id)
) TABLESPACE pg_default;

create table public.roles (
  id bigint generated always as identity not null,
  role_name text not null,
  constraint roles_pkey primary key (id),
  constraint roles_role_name_key unique (role_name)
) TABLESPACE pg_default;

create table public.seasons (
  id bigint generated by default as identity not null,
  season_name text null,
  constraint seasons_pkey primary key (id)
) TABLESPACE pg_default;

create table public.socials (
  id bigint generated by default as identity not null,
  platform text not null,
  url text null,
  constraint socials_pkey primary key (id)
) TABLESPACE pg_default;

create table public.sponsor_company (
  id bigint generated by default as identity not null,
  image_url text null,
  company_name text null,
  constraint sponsor_company_pkey primary key (id)
) TABLESPACE pg_default;

create table public.sponsors (
  id bigint generated by default as identity not null,
  name text not null,
  image_url text null,
  company_id bigint null,
  constraint sponsors_pkey primary key (id),
  constraint sponsors_company_id_fkey foreign KEY (company_id) references sponsor_company (id) on update CASCADE on delete CASCADE
) TABLESPACE pg_default;

create table public.team_competitions (
  id bigint generated always as identity not null,
  team_id bigint not null,
  competition_id bigint not null,
  constraint team_competitions_pkey primary key (id),
  constraint team_competitions_unique_pair unique (team_id, competition_id),
  constraint team_competitions_competition_id_fkey foreign KEY (competition_id) references competitions (id) on delete CASCADE,
  constraint team_competitions_team_id_fkey foreign KEY (team_id) references teams (id) on delete CASCADE
) TABLESPACE pg_default;

create table public.team_members (
  id bigint generated always as identity not null,
  name text not null,
  created_at timestamp with time zone null default now(),
  profile_image_url text null,
  is_graduated boolean null,
  is_active boolean null,
  constraint team_members_pkey primary key (id)
) TABLESPACE pg_default;

create table public.teams (
  id bigint generated always as identity not null,
  team_name text not null,
  team_number integer not null,
  team_code text null,
  is_active boolean null,
  season_id bigint null,
  constraint teams_pkey primary key (id),
  constraint teams_season_id_fkey foreign KEY (season_id) references seasons (id) on update CASCADE on delete CASCADE
) TABLESPACE pg_default;

-- user_accounts table and triggers
create table public.user_accounts (
  id uuid references auth.users on delete cascade not null primary key,
  email text not null,
  full_name text null,
  position text null, -- 'Media', 'Member', or 'Team Player'
  team_id bigint references public.teams(id) on delete set null,
  created_at timestamp with time zone default timezone('utc'::text, now()) not null
);

alter table public.user_accounts enable row level security;

create policy "Users can view own account data" 
  on public.user_accounts for select 
  using (auth.uid() = id);

create policy "Users can insert own account data" 
  on public.user_accounts for insert 
  with check (auth.uid() = id);

create policy "Users can update own account data" 
  on public.user_accounts for update 
  using (auth.uid() = id);

create or replace function public.handle_new_user()
returns trigger
language plpgsql
security definer set search_path = public
as $$
begin
  insert into public.user_accounts (id, email, full_name, position, team_id)
  values (
    new.id,
    new.email,
    new.raw_user_meta_data->>'full_name',
    new.raw_user_meta_data->>'position',
    (new.raw_user_meta_data->>'team_id')::bigint
  );
  return new;
end;
$$;

create trigger on_auth_user_created
  after insert on auth.users
  for each row execute procedure public.handle_new_user();

-- Storage Configuration
-- Buckets
insert into storage.buckets (id, name, public)
values ('competition_matches', 'competition_matches', true)
on conflict (id) do nothing;

-- RLS Policies for competition_matches bucket
create policy "Allow Media users to upload match assets"
on storage.objects for insert
to authenticated
with check (
  bucket_id = 'competition_matches' 
  and (select position from public.user_accounts where id = auth.uid()) = 'Media'
);

create policy "Allow Media users to update match assets"
on storage.objects for update
to authenticated
using (
  bucket_id = 'competition_matches' 
  and (select position from public.user_accounts where id = auth.uid()) = 'Media'
);

create policy "Allow Media users to delete match assets"
on storage.objects for delete
to authenticated
using (
  bucket_id = 'competition_matches' 
  and (select position from public.user_accounts where id = auth.uid()) = 'Media'
);

create policy "Allow public to view match assets"
on storage.objects for select
to public
using (bucket_id = 'competition_matches');